From da1ff4a8d60110070316cb3add221e566bf5b48d Mon Sep 17 00:00:00 2001
From: Esteban Urrutia <esteuwu@proton.me>
Date: Wed, 1 Jul 2026 22:25:58 -0400
Subject: [PATCH 5/5] firmware: qcom: scm: Allow QSEECOM on ThinkPhone by
 motorola

While this device doesn't have UEFI settings per se (therefore the uefisecapp TA is useless in this case), this allows the QSEE interface to be exposed.
---
 drivers/firmware/qcom/qcom_scm.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/firmware/qcom/qcom_scm.c b/drivers/firmware/qcom/qcom_scm.c
index f35f2ee39130..bc884ae4d8c5 100644
--- a/drivers/firmware/qcom/qcom_scm.c
+++ b/drivers/firmware/qcom/qcom_scm.c
@@ -2325,6 +2325,7 @@ static const struct of_device_id qcom_scm_qseecom_allowlist[] __maybe_unused = {
 	{ .compatible = "microsoft,denali", },
 	{ .compatible = "microsoft,romulus13", },
 	{ .compatible = "microsoft,romulus15", },
+	{ .compatible = "motorola,bronco", },
 	{ .compatible = "qcom,glymur-crd" },
 	{ .compatible = "qcom,hamoa-iot-evk" },
 	{ .compatible = "qcom,mahua-crd" },
-- 
2.55.0

