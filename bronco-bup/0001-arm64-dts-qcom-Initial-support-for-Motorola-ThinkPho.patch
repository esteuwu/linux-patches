+&spi4 {
+	status = "okay";
+
+	gt9916p@0 {
+		/* GT9916P, not GT9916 */
+		compatible = "goodix,gt9916";
+		reg = <0>;
+		interrupt-parent = <&tlmm>;
+		interrupts = <21 IRQ_TYPE_EDGE_BOTH>;
+		reset-gpios = <&tlmm 20 GPIO_ACTIVE_LOW>;
+		avdd-supply = <&vreg_l11c_3p3>;
+		vddio-supply = <&vreg_l2c_1p8>;
+		spi-max-frequency = <1000000>;
+		touchscreen-size-x = <17280>;
+		touchscreen-size-y = <38400>;
+	};
+};
+
+&swr0 {
+	status = "okay";
+
+	wsa8830_l: wsa8830@0,1 {
+		compatible = "sdw10217020200";
+		reg = <0 1>;
+		vdd-supply = <&vreg_s10b_1p8>;
+		#thermal-sensor-cells = <0>;
+		#sound-dai-cells = <0>;
+		powerdown-gpios = <&tlmm 1 GPIO_ACTIVE_LOW>;
+		sound-name-prefix = "SpkrLeft";
+		/*
+		 * WSA8830 Port 1 (DAC)     <=> SWR0 Port 1 (SPKR_L)
+		 * WSA8830 Port 2 (COMP)    <=> SWR0 Port 2 (SPKR_L_COMP)
+		 * WSA8830 Port 3 (BOOST)   <=> SWR0 Port 3 (SPKR_L_BOOST)
+		 * WSA8830 Port 4 (VISENSE) <=> SWR0 Port 7 (SPKR_L_VI)
+		 */
+		qcom,port-mapping = <1 2 3 7>;
+	};
+
+	wsa8835_r: wsa8835@0,2 {
+		compatible = "sdw10217020200";
+		reg = <0 2>;
+		vdd-supply = <&vreg_s10b_1p8>;
+		#thermal-sensor-cells = <0>;
+		#sound-dai-cells = <0>;
+		powerdown-gpios = <&tlmm 87 GPIO_ACTIVE_LOW>;
+		sound-name-prefix = "SpkrRight";
+		/*
+		 * WSA8835 Port 1 (DAC)     <=> SWR0 Port 4 (SPKR_R)
+		 * WSA8835 Port 2 (COMP)    <=> SWR0 Port 5 (SPKR_R_COMP)
+		 * WSA8835 Port 3 (BOOST)   <=> SWR0 Port 6 (SPKR_R_BOOST)
+		 * WSA8835 Port 4 (VISENSE) <=> SWR0 Port 8 (SPKR_R_VI)
+		 */
+		qcom,port-mapping = <4 5 6 8>;
+	};
+};
+
+&swr1 {
+	status = "okay";
+
+	wcd9380_rx: wcd9380-rx@0,4 {
+		compatible = "sdw20217010d00";
+		reg = <0 4>;
+		/*
+		 * WCD9380 RX Port 1 (HPH_L/R)      <=> SWR1 Port 1 (HPH_L/R)
+		 * WCD9380 RX Port 2 (CLSH)         <=> SWR1 Port 2 (CLSH)
+		 * WCD9380 RX Port 3 (COMP_L/R)     <=> SWR1 Port 3 (COMP_L/R)
+		 * WCD9380 RX Port 4 (LO)           <=> SWR1 Port 4 (LO)
+		 * WCD9380 RX Port 5 (DSD_L/R)      <=> SWR1 Port 5 (DSD_L/R)
+		 */
+		qcom,rx-port-mapping = <1 2 3 4 5>;
+	};
+};
+
+&swr2 {
+	status = "okay";
+
+	wcd9380_tx: wcd9380-tx@0,3 {
+		compatible = "sdw20217010d00";
+		reg = <0 3>;
+		/*
+		 * WCD9380 TX Port 1 (ADC1,2)             <=> SWR2 Port 1 (TX SWR_INPUT 0,1,2,3)
+		 * WCD9380 TX Port 2 (ADC3,4)             <=> SWR2 Port 1 (TX SWR_INPUT 0,1,2,3)
+		 * WCD9380 TX Port 3 (DMIC0,1,2,3 & MBHC) <=> SWR2 Port 2 (TX SWR_INPUT 4,5,6,7)
+		 * WCD9380 TX Port 4 (DMIC4,5,6,7)        <=> SWR2 Port 3 (TX SWR_INPUT 8,9,10,11)
+		 */
+		qcom,tx-port-mapping = <1 1 2 3>;
+	};
+};
+
+&tlmm {
+	/*
+	 * 28-31: NFC SE (SPI)
+	 * 36-39: Fingerprint (SPI)
+	 */
+	gpio-reserved-ranges = <28 4>, <36 4>;
+
+	key_mute_default: key-mute-default-state {
