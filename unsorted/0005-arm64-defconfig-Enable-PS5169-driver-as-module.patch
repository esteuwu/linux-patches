From e234f28df25a9e4af0b00e6a7f44fa4a61973927 Mon Sep 17 00:00:00 2001
From: Esteban Urrutia <esteuwu@proton.me>
Date: Wed, 1 Jul 2026 22:58:31 -0400
Subject: [PATCH 5/6] arm64: defconfig: Enable PS5169 driver as module

This driver is used in motorola-bronco for redriving the USB Type-C port.
Enable it as a module.
---
 arch/arm64/configs/defconfig | 1 +
 1 file changed, 1 insertion(+)

diff --git a/arch/arm64/configs/defconfig b/arch/arm64/configs/defconfig
index 6ec8d3a69c98..331cf3a967c7 100644
--- a/arch/arm64/configs/defconfig
+++ b/arch/arm64/configs/defconfig
@@ -1269,6 +1269,7 @@ CONFIG_TYPEC_MUX_FSA4480=m
 CONFIG_TYPEC_MUX_GPIO_SBU=m
 CONFIG_TYPEC_MUX_IT5205=m
 CONFIG_TYPEC_MUX_NB7VPQ904M=m
+CONFIG_TYPEC_MUX_PS5169=m
 CONFIG_TYPEC_MUX_PS883X=m
 CONFIG_TYPEC_MUX_PTN36502=m
 CONFIG_TYPEC_MUX_WCD939X_USBSS=m
-- 
2.55.0

