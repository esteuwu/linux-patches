From 32cb954974d3b8a7c46df07fc1ddf2819fdf8438 Mon Sep 17 00:00:00 2001
From: Esteban Urrutia <esteuwu@proton.me>
Date: Wed, 1 Jul 2026 22:31:38 -0400
Subject: [PATCH 1/6] dt-bindings: usb: fsa4480: Add compatible for WAS4780C

The fsa4480 driver is mostly compatible with the Willsemi WAS4780C, though the data-lanes property doesn't match that of FSA4480.
Document the correct behavior and add compatible.
---
 Documentation/devicetree/bindings/usb/fcs,fsa4480.yaml | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/Documentation/devicetree/bindings/usb/fcs,fsa4480.yaml b/Documentation/devicetree/bindings/usb/fcs,fsa4480.yaml
index 89b1fb90aeeb..59f16dc2cb1f 100644
--- a/Documentation/devicetree/bindings/usb/fcs,fsa4480.yaml
+++ b/Documentation/devicetree/bindings/usb/fcs,fsa4480.yaml
@@ -16,6 +16,7 @@ properties:
       - items:
           - enum:
               - ocs,ocp96011
+              - willsemi,was4780c
           - const: fcs,fsa4480
 
   reg:
@@ -55,7 +56,7 @@ properties:
                   Default AUX/SBU layout (FSA4480)
                   - AUX+ connected to SBU2
                   - AUX- connected to SBU1
-                  Default AUX/SBU layout (OCP96011)
+                  Default AUX/SBU layout (OCP96011/WAS4780C)
                   - AUX+ connected to SBU1
                   - AUX- connected to SBU2
               - items:
@@ -65,7 +66,7 @@ properties:
                   Swapped AUX/SBU layout (FSA4480)
                   - AUX+ connected to SBU1
                   - AUX- connected to SBU2
-                  Swapped AUX/SBU layout (OCP96011)
+                  Swapped AUX/SBU layout (OCP96011/WAS4780C)
                   - AUX+ connected to SBU2
                   - AUX- connected to SBU1
 
