From 8886714ff2c4daa3f4a5e463079d092a2dc9018d Mon Sep 17 00:00:00 2001
From: Esteban Urrutia <esteuwu@proton.me>
Date: Sat, 16 May 2026 18:10:14 -0400
Subject: [PATCH 01/13] arm64: dts: qcom: Initial Snapdragon 8+ Gen 1 (SM8475)
 support

The Snapdragon 8+ Gen 1 SoC sits somewhere in between the SM8450 and the SM8550.
This SoC is used in motorola-bronco. Add support for it using the SM8450 dts as a starting point.
---
 arch/arm64/boot/dts/qcom/sm8475.dtsi | 176 +++++++++++++++++++++++++++
 1 file changed, 176 insertions(+)
 create mode 100644 arch/arm64/boot/dts/qcom/sm8475.dtsi

diff --git a/arch/arm64/boot/dts/qcom/sm8475.dtsi b/arch/arm64/boot/dts/qcom/sm8475.dtsi
new file mode 100644
index 000000000000..a3258588af6f
--- /dev/null
+++ b/arch/arm64/boot/dts/qcom/sm8475.dtsi
@@ -0,0 +1,176 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Device tree source for the Qualcomm Snapdragon 8+ Gen 1 SoC,
+ * which inherits most of its resources from the SM8450 device tree source
+ * and some of its peripherals from the Snapdragon 8 Gen 2 (SM8550) SoC.
+ *
+ * Copyright (c) 2026 Esteban Urrutia <esteuwu@proton.me>
+ */
+
+#include "sm8450.dtsi"
+
+/* Delete redefined nodes */
+/delete-node/ &gpu_opp_table;
+/delete-node/ &ufs_mem_phy;
+
+/* Delete non-applicable reserved memory nodes */
+/delete-node/ &oem_vm_mem;
+
+&camcc {
+	compatible = "qcom,sm8475-camcc";
+};
+
+&dispcc {
+	compatible = "qcom,sm8475-dispcc";
+};
+
+&gcc {
+	compatible = "qcom,sm8475-gcc";
+};
+
+&gpu {
+	gpu_opp_table: opp-table {
+		compatible = "operating-points-v2";
+
+		opp-900000000 {
+			opp-hz = /bits/ 64 <900000000>;
+			opp-level = <RPMH_REGULATOR_LEVEL_TURBO_L1>;
+		};
+
+		opp-862000000 {
+			opp-hz = /bits/ 64 <862000000>;
+			opp-level = <RPMH_REGULATOR_LEVEL_TURBO>;
+		};
+
+		opp-815000000 {
+			opp-hz = /bits/ 64 <815000000>;
+			opp-level = <RPMH_REGULATOR_LEVEL_NOM_L1>;
+		};
+
+		opp-765000000 {
+			opp-hz = /bits/ 64 <765000000>;
+			opp-level = <RPMH_REGULATOR_LEVEL_NOM>;
+		};
+
+		opp-710000000 {
+			opp-hz = /bits/ 64 <710000000>;
+			opp-level = <RPMH_REGULATOR_LEVEL_SVS_L2>;
+		};
+
+		opp-645000000 {
+			opp-hz = /bits/ 64 <645000000>;
+			opp-level = <RPMH_REGULATOR_LEVEL_SVS_L1>;
+		};
+
+		opp-580000000 {
+			opp-hz = /bits/ 64 <580000000>;
+			opp-level = <RPMH_REGULATOR_LEVEL_SVS_L0>;
+		};
+
+		opp-515000000 {
+			opp-hz = /bits/ 64 <515000000>;
+			opp-level = <RPMH_REGULATOR_LEVEL_SVS>;
+		};
+
+		opp-439000000 {
+			opp-hz = /bits/ 64 <439000000>;
+			opp-level = <RPMH_REGULATOR_LEVEL_LOW_SVS_L2>;
+		};
+
+		opp-364000000 {
+			opp-hz = /bits/ 64 <364000000>;
+			opp-level = <RPMH_REGULATOR_LEVEL_LOW_SVS_L1>;
+		};
+
+		opp-324000000 {
+			opp-hz = /bits/ 64 <324000000>;
+			opp-level = <RPMH_REGULATOR_LEVEL_LOW_SVS>;
+		};
+
+		opp-285000000 {
+			opp-hz = /bits/ 64 <285000000>;
+			opp-level = <RPMH_REGULATOR_LEVEL_LOW_SVS_D1>;
+		};
+
+		opp-220000000 {
+			opp-hz = /bits/ 64 <220000000>;
+			opp-level = <RPMH_REGULATOR_LEVEL_MIN_SVS>;
+		};
+	};
+};
+
+&gpucc {
+	compatible = "qcom,sm8475-gpucc";
+};
+
+&pcie0_phy {
+	compatible = "qcom,sm8475-qmp-gen3x1-pcie-phy";
+};
+
+&soc {
+	ufs_mem_phy: phy@1d80000 {
+		/* ufs_mem_phy was taken from SM8450. All values are identical except for both compatible and reg. */
+		compatible = "qcom,sm8475-qmp-ufs-phy";
+		reg = <0 0x01d80000 0 0x2000>;
+
+		clock-names = "ref", "ref_aux", "qref";
+		clocks = <&rpmhcc RPMH_CXO_CLK>,
+			 <&gcc GCC_UFS_PHY_PHY_AUX_CLK>,
+			 <&gcc GCC_UFS_0_CLKREF_EN>;
+
+		power-domains = <&gcc UFS_PHY_GDSC>;
+
+		resets = <&ufs_mem_hc 0>;
+		reset-names = "ufsphy";
+
+		#clock-cells = <1>;
+		#phy-cells = <0>;
+
+		status = "disabled";
+	};
+};
+
+&swr0 {
+	/* SM8475 has an additional undocumented din port on swr0 */
+	qcom,din-ports = <3>;
+
+	/* Adapted from SM8450 */
+	qcom,ports-sinterval-low =	/bits/ 8 <0x07 0x1f 0x3f 0x07 0x1f 0x3f 0x0f 0x0f 0xff>;
+	qcom,ports-offset1 =		/bits/ 8 <0x01 0x02 0x0c 0x06 0x12 0x0d 0x07 0x0a 0xff>;
+	qcom,ports-offset2 =		/bits/ 8 <0xff 0x00 0x1f 0xff 0x00 0x1f 0x00 0x00 0xff>;
+	qcom,ports-hstart =		/bits/ 8 <0xff 0xff 0xff 0xff 0xff 0xff 0xff 0xff 0xff>;
+	qcom,ports-hstop =		/bits/ 8 <0xff 0xff 0xff 0xff 0xff 0xff 0xff 0xff 0xff>;
+	qcom,ports-word-length =	/bits/ 8 <0xff 0xff 0xff 0xff 0xff 0xff 0xff 0xff 0xff>;
+	qcom,ports-block-pack-mode =	/bits/ 8 <0xff 0xff 0x01 0xff 0xff 0x01 0xff 0xff 0xff>;
+	qcom,ports-block-group-count =	/bits/ 8 <0xff 0xff 0xff 0xff 0xff 0xff 0xff 0xff 0xff>;
+	qcom,ports-lane-control =	/bits/ 8 <0xff 0xff 0xff 0xff 0xff 0xff 0xff 0xff 0xff>;
+};
+
+&swr1 {
+	/* SM8475 has an undocumented din port on swr1 */
+	qcom,din-ports = <1>;
+
+	/* Adapted from SM8450 */
+	qcom,ports-sinterval =		/bits/ 16 <0x03 0x3f 0x1f 0x07 0x00 0x18f 0xff>;
+	qcom,ports-offset1 =		/bits/ 8 <0x00 0x00 0x0b 0x01 0x00 0x00 0xff>;
+	qcom,ports-offset2 =		/bits/ 8 <0x00 0x00 0x0b 0x00 0x00 0x00 0xff>;
+	qcom,ports-hstart =		/bits/ 8 <0xff 0x03 0xff 0xff 0xff 0x08 0xff>;
+	qcom,ports-hstop =		/bits/ 8 <0xff 0x06 0xff 0xff 0xff 0x08 0xff>;
+	qcom,ports-word-length =	/bits/ 8 <0x01 0x07 0x04 0xff 0xff 0x0f 0xff>;
+	qcom,ports-block-pack-mode =	/bits/ 8 <0xff 0x00 0x01 0xff 0xff 0x00 0xff>;
+	qcom,ports-block-group-count =	/bits/ 8 <0xff 0xff 0xff 0xff 0x00 0x00 0xff>;
+	qcom,ports-lane-control =	/bits/ 8 <0x01 0x00 0x00 0x00 0x00 0x00 0xff>;
+};
+
+&usb_1_hsphy {
+	compatible = "qcom,sm8475-snps-eusb2-phy", "qcom,sm8550-snps-eusb2-phy";
+	reg = <0 0x088e3000 0 0x154>;
+};
+
+&usb_1_qmpphy {
+	compatible = "qcom,sm8475-qmp-usb3-dp-phy";
+};
+
+&videocc {
+	compatible = "qcom,sm8475-videocc";
+};
-- 
2.55.0

